# ───────────────────────────────────────────────────────────────
# Magxor Music — Environment Variables
# Copy this file to .env and fill in your values.
# ───────────────────────────────────────────────────────────────

# Google Gemini API key (for AI lyrics improvement)
GEMINI_API_KEY="your_gemini_api_key_here"

# Kie.ai API token (for music generation)
VITE_KIE_API_TOKEN="your_kie_api_token_here"

# Webhook HMAC key for verifying Kie.ai callback signatures
WEBHOOK_HMAC_KEY="your_webhook_hmac_key_here"

# ─── IMPORTANT: Public URL of this server ───────────────────────
# Kie.ai needs to call a PUBLIC URL with your generated song.
# Without this, songs will NEVER arrive to the frontend!
#
# Options:
#   1. Local dev: Use ngrok → run `ngrok http 3000`
#      then set APP_URL=https://xxxx.ngrok-free.app
#
#   2. Production: Set to your deployed domain
#      APP_URL=https://music.magxor.com
#
APP_URL="https://your-public-url.ngrok-free.app"

# MercadoPago access token (for payment processing)
# Get it from: https://www.mercadopago.com/developers/panel
# Use TEST token for sandbox: TEST-xxxx...
# Use PROD token for production: APP_USR-xxxx...
MERCADOPAGO_ACCESS_TOKEN="TEST-your_mercadopago_token_here"

# Optional: Server port (default: 3000)
# PORT=3000
