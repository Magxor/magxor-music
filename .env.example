# ───────────────────────────────────────────────────────────────
# MAGXOR Music — Environment Variables
# Copy this file to .env and fill in your values.
# ───────────────────────────────────────────────────────────────

# Google Gemini API key (for AI lyrics improvement)
GEMINI_API_KEY="your_gemini_api_key_here"

# OpenAI API key (as a redundant AI provider for lyrics)
OPENAI_API_KEY="your_openai_api_key_here"

# Kie.ai API token (for music generation)
VITE_KIE_API_TOKEN="your_kie_api_token_here"

# Webhook HMAC key for verifying Kie.ai callback signatures
WEBHOOK_HMAC_KEY="your_webhook_hmac_key_here"

# ─── Upstash Redis (Sistema de Cupones) ────────────────────────
# Obtener en: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token_here"

# ─── MercadoPago (Pagos en ARS) ────────────────────────────────
# Obtener en: https://www.mercadopago.com/developers/panel
MERCADOPAGO_ACCESS_TOKEN="TEST-your_mercadopago_token_here"

# ─── Public URL ─────────────────────────────────────────────────
# Kie.ai necesita una URL PÚBLICA para llamar con la canción generada
APP_URL="https://magxormusic.vercel.app"

# ─── Precios ────────────────────────────────────────────────────
# PRICE_FULL=30000 (sin cupón)
# PRICE_DISCOUNTED=15000 (con cupón 50% OFF)
