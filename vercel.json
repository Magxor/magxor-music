{
  "version": 2,
  "name": "magxor-music",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "js/**/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "manifest.json",
      "use": "@vercel/static"
    },
    {
      "src": "sw.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/generate",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/task/(.+)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/suno-callback",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/ai/lyrics",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/generate-coupon",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/create-payment",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/validate",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/claim",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/social/counter",
      "dest": "/api/index.js"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}